# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/lancepay?sslmode=require"
# For Neon: use the non-pooling connection string for migrations
DIRECT_URL="postgresql://user:password@host:5432/lancepay?sslmode=require"

# ─── Privy (Auth + Embedded Wallets) ─────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# ─── Stellar ─────────────────────────────────────────────────────────────────
# "testnet" | "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK="testnet"
# Platform fee collection wallet
STELLAR_PLATFORM_WALLET_SECRET="your-stellar-secret-key"
NEXT_PUBLIC_STELLAR_PLATFORM_WALLET_PUBLIC="your-stellar-public-key"

# ─── MoonPay (Fiat → USDC on-ramp) ───────────────────────────────────────────
NEXT_PUBLIC_MOONPAY_API_KEY="your-moonpay-publishable-key"
MOONPAY_SECRET_KEY="your-moonpay-secret-key"
MOONPAY_WEBHOOK_SECRET="your-moonpay-webhook-secret"

# ─── Yellow Card (USDC → NGN off-ramp) ───────────────────────────────────────
YELLOW_CARD_API_KEY="your-yellowcard-api-key"
YELLOW_CARD_API_SECRET="your-yellowcard-api-secret"
# "sandbox" | "production"
YELLOW_CARD_ENV="sandbox"

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@lancepay.io"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Platform fee percentage (e.g. 0.8 = 0.8%)
NEXT_PUBLIC_PLATFORM_FEE_PERCENT="0.8"

# ─── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET="your-secure-random-cron-secret"
