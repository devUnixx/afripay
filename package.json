{
  "name": "afripay",
  "version": "0.1.0",
  "private": false,
  "description": "Instant international payments for Nigerian freelancers — powered by Stellar and stablecoins.",
  "keywords": ["stellar", "payments", "freelance", "nigeria", "usdc", "fintech", "open-source"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/afripay"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --passWithNoTests",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/client": "6.8.2",
    "@privy-io/react-auth": "2.5.0",
    "@privy-io/server-auth": "1.19.0",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-tooltip": "1.1.6",
    "@stellar/stellar-sdk": "13.1.0",
    "axios": "1.7.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.468.0",
    "next": "15.3.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@hookform/resolvers": "3.9.1",
    "react-hook-form": "7.54.2",
    "resend": "4.0.1",
    "tailwind-merge": "2.6.0",
    "zod": "3.24.1",
    "nanoid": "5.0.9",
    "jose": "5.9.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@tailwindcss/postcss": "4.1.7",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "9.17.0",
    "eslint-config-next": "15.3.2",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "lint-staged": "15.3.0",
    "prettier": "3.4.2",
    "prisma": "6.8.2",
    "tailwindcss": "4.1.7",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,css}": ["prettier --write"]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
